# vprod — environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Optional — override the data directory (default: /var/lib/vprod/<instance> in production,
# or data/ in development)
# VPROD_DATA_DIR=/var/lib/vprod/vprod
